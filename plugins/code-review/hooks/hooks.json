{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/user_prompt_submit_intent_gate.py",
            "timeout": 10,
            "statusMessage": "Detecting code-review intent"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/pre_tool_use_policy_gate.py",
            "timeout": 15,
            "statusMessage": "Checking code-review tool policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/post_tool_use_verification_gate.py",
            "timeout": 15,
            "statusMessage": "Reviewing tool result"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*(reviewer|verifier|auditor|planner|implementer|explorer).*",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/subagent_start_context_gate.py",
            "timeout": 10,
            "statusMessage": "Adding code-review subagent policy"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*(reviewer|verifier|auditor|planner|implementer|explorer).*",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/subagent_stop_output_gate.py",
            "timeout": 15,
            "statusMessage": "Validating subagent output"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/stop_final_report_gate.py",
            "timeout": 15,
            "statusMessage": "Checking final code-review report"
          }
        ]
      }
    ]
  }
}
