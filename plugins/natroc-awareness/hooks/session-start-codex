#!/usr/bin/env bash
# =============================================================================
# SessionStart hook for natroc-awareness (Codex)
#
# Keep startup light: inject only the bootstrap skill. Plugin marketplace and
# manifest inspection happens on demand after a task points to a plugin domain.
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="${PLUGIN_ROOT:-$(cd "${SCRIPT_DIR}/.." && pwd)}"

export CODEX_PLUGIN_ROOT="${PLUGIN_ROOT}"
export CLAUDE_PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$PLUGIN_ROOT}"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

SKILL_FILE="${PLUGIN_ROOT}/skills/using-natroc-plugins/SKILL.md"
if [ -f "$SKILL_FILE" ]; then
    skill_content=$(cat "$SKILL_FILE")
else
    skill_content="# Natroc Plugin Awareness\n\nError: using-natroc-plugins SKILL.md not found."
fi

skill_escaped=$(escape_for_json "$skill_content")
session_context="<EXTREMELY-IMPORTANT>\nYou have Natroc Plugin Awareness.\n\n**Below is the full content of your 'natroc-awareness:using-natroc-plugins' skill. For all other Natroc plugin skills, follow the Codex skill-loading instructions in that skill:**\n\n${skill_escaped}\n</EXTREMELY-IMPORTANT>"

printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$session_context"

exit 0
