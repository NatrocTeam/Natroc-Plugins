{
  "description": "Load compact Natroc plugin routing context at session start.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/session_start_context.py",
            "timeout": 10,
            "statusMessage": "Loading Natroc plugin awareness"
          }
        ]
      }
    ]
  }
}
